<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.uranai.repository.FortuneMapper">

	<select id="selectAll" resultType="com.example.uranai.entity.Fortune">
		SELECT
			id,
			month_result AS monthResult,
			day_result AS dayResult
		FROM fortune
	</select>
</mapper>